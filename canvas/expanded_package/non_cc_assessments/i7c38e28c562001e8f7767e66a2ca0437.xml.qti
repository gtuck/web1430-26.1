<questestinterop xmlns="http://www.imsglobal.org/xsd/ims_qtiasiv1p2" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.imsglobal.org/xsd/ims_qtiasiv1p2 http://www.imsglobal.org/xsd/ims_qtiasiv1p2p1.xsd"><assessment ident="i7c38e28c562001e8f7767e66a2ca0437" title="Quiz 4 – DOM, Events, and Forms"><qtimetadata><qtimetadatafield><fieldlabel>cc_maxattempts</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield></qtimetadata><section ident="root_section"><item ident="i4646c2a5f223d93de09e83d66a448e3b" title="Selector"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>original_answer_ids</fieldlabel><fieldentry>selector_a1,selector_a2,selector_a3,selector_a4</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;Which DOM method returns the first element that matches a CSS selector?&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="selector_a1"><material><mattext texttype="text/html">&lt;p&gt;getElementByStyle&lt;/p&gt;</mattext></material></response_label><response_label ident="selector_a2"><material><mattext texttype="text/html">&lt;p&gt;querySelector&lt;/p&gt;</mattext></material></response_label><response_label ident="selector_a3"><material><mattext texttype="text/html">&lt;p&gt;firstElement&lt;/p&gt;</mattext></material></response_label><response_label ident="selector_a4"><material><mattext texttype="text/html">&lt;p&gt;matchNode&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">selector_a2</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="id25d51583af2638366834aabb3ce065e" title="Event listener"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>original_answer_ids</fieldlabel><fieldentry>event-listener_a1,event-listener_a2,event-listener_a3,event-listener_a4</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;Which method attaches a handler for a click event?&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="event-listener_a1"><material><mattext texttype="text/html">&lt;p&gt;listen(&amp;#x27;click&amp;#x27;)&lt;/p&gt;</mattext></material></response_label><response_label ident="event-listener_a2"><material><mattext texttype="text/html">&lt;p&gt;onClick()&lt;/p&gt;</mattext></material></response_label><response_label ident="event-listener_a3"><material><mattext texttype="text/html">&lt;p&gt;addEventListener(&amp;#x27;click&amp;#x27;, handler)&lt;/p&gt;</mattext></material></response_label><response_label ident="event-listener_a4"><material><mattext texttype="text/html">&lt;p&gt;bindClick(handler)&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">event-listener_a3</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="iabb7e3b289710bb6d4eeca2f94e2a7b4" title="Accessible feedback"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>original_answer_ids</fieldlabel><fieldentry>accessible-feedback_a1,accessible-feedback_a2,accessible-feedback_a3,accessible-feedback_a4</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;Which form pattern improves accessibility?&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="accessible-feedback_a1"><material><mattext texttype="text/html">&lt;p&gt;Only color-based errors&lt;/p&gt;</mattext></material></response_label><response_label ident="accessible-feedback_a2"><material><mattext texttype="text/html">&lt;p&gt;Clear labels and error text tied to fields&lt;/p&gt;</mattext></material></response_label><response_label ident="accessible-feedback_a3"><material><mattext texttype="text/html">&lt;p&gt;Placeholder text instead of labels&lt;/p&gt;</mattext></material></response_label><response_label ident="accessible-feedback_a4"><material><mattext texttype="text/html">&lt;p&gt;Hidden submit buttons&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">accessible-feedback_a2</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="i8454c9deaafd3f8a090ac83175866c39" title="Prevent default"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>true_false_question</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>original_answer_ids</fieldlabel><fieldentry>prevent-default_true,prevent-default_false</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;event.preventDefault() can stop a form from submitting immediately.&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="prevent-default_true"><material><mattext texttype="text/html">&lt;p&gt;True&lt;/p&gt;</mattext></material></response_label><response_label ident="prevent-default_false"><material><mattext texttype="text/html">&lt;p&gt;False&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">prevent-default_true</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item><item ident="id23fc633b1eb481bf8cd9cc2b5e1c02a" title="State source"><itemmetadata><qtimetadata><qtimetadatafield><fieldlabel>question_type</fieldlabel><fieldentry>multiple_choice_question</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>points_possible</fieldlabel><fieldentry>1</fieldentry></qtimetadatafield><qtimetadatafield><fieldlabel>original_answer_ids</fieldlabel><fieldentry>state-source_a1,state-source_a2,state-source_a3,state-source_a4</fieldentry></qtimetadatafield></qtimetadata></itemmetadata><presentation><material><mattext texttype="text/html">&lt;p&gt;For many forms, the most trustworthy source of current user input is:&lt;/p&gt;</mattext></material><response_lid ident="response1" rcardinality="Single"><render_choice><response_label ident="state-source_a1"><material><mattext texttype="text/html">&lt;p&gt;A comment in the code&lt;/p&gt;</mattext></material></response_label><response_label ident="state-source_a2"><material><mattext texttype="text/html">&lt;p&gt;The value of the form control&lt;/p&gt;</mattext></material></response_label><response_label ident="state-source_a3"><material><mattext texttype="text/html">&lt;p&gt;A hard-coded default&lt;/p&gt;</mattext></material></response_label><response_label ident="state-source_a4"><material><mattext texttype="text/html">&lt;p&gt;The page title&lt;/p&gt;</mattext></material></response_label></render_choice></response_lid></presentation><resprocessing><outcomes><decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal" /></outcomes><respcondition continue="No"><conditionvar><varequal respident="response1">state-source_a2</varequal></conditionvar><setvar action="Set" varname="SCORE">100</setvar></respcondition></resprocessing></item></section></assessment></questestinterop>